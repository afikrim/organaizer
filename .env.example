# OrganAIzer environment variables
# Copy this file to .env and fill in real values. Never commit .env.
#
# Port conventions:
#   Landing (Astro)  : 4321
#   Web app (Vite)   : 5173
#   API (NestJS)     : 3000  — base path: /v1

# ──────────────────────────────────────────────
# API
# ──────────────────────────────────────────────
API_PORT=3000
API_BASE_PATH=/v1
PERSISTENCE_DRIVER=memory
STORAGE_DRIVER=memory
VISION_DRIVER=memory
DATABASE_URL=postgresql://organaizer:organaizer@localhost:54322/organaizer?schema=public

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:4321,http://localhost:5173

# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ──────────────────────────────────────────────
# Google Gemini
# ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────
# Storage (e.g. Supabase Storage or S3-compatible)
# ──────────────────────────────────────────────
STORAGE_BUCKET=organaizer-uploads
STORAGE_REGION=eu-west-1
STORAGE_ENDPOINT=https://your-storage-endpoint

# Supabase Storage driver — required only when STORAGE_DRIVER=supabase.
# (Re-uses SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY from the Supabase section above.)
SUPABASE_STORAGE_BUCKET=analyses
# Signed-URL lifetime in seconds (default 24h). Must be a positive integer.
SUPABASE_SIGNED_URL_TTL=86400

# ──────────────────────────────────────────────
# Public env vars (safe to expose in browser bundles)
# Prefix with PUBLIC_ / VITE_ / NEXT_PUBLIC_ as required by each framework
# ──────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
