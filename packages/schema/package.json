{
  "name": "@organaizer/schema",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc --project tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({ type: 'commonjs' }))\"",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'schema: lint not configured yet'",
    "test": "echo 'schema: test not configured yet'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.25.0"
  }
}
